# ── Прод-окружение для сервера (скопировать в .env на сервере) ──
# DATABASE_URL для web в docker задаётся в docker-compose автоматически (postgres:5432).
# Здесь задаём пароль БД, секреты и публичные адреса.

# Пароль PostgreSQL (ОБЯЗАТЕЛЬНО смените на длинный случайный)
POSTGRES_PASSWORD="ПОМЕНЯЙТЕ_на_длинный_пароль"

# DATABASE_URL нужен для локальных команд prisma на сервере (если запускаете вне docker)
DATABASE_URL="postgresql://sdelka:ПОМЕНЯЙТЕ_на_длинный_пароль@localhost:5433/sdelka_db?schema=public"

# NextAuth — секрет сгенерировать:  openssl rand -base64 32
NEXTAUTH_SECRET="СГЕНЕРИРУЙТЕ_случайную_строку"
NEXTAUTH_URL="https://sdelkasafe.ru"
APP_URL="https://sdelkasafe.ru"

# Telegram
TELEGRAM_BOT_TOKEN="ваш_токен_бота"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="SdelkaSafeBot"
TELEGRAM_WEBHOOK_SECRET="придумайте_секрет_вебхука"
ADMIN_TELEGRAM_CHAT_ID=""

# TON — реальный кошелёк платформы (для пополнений баланса/буста)
PLATFORM_TON_WALLET="UQ...ваш_адрес"
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL="https://sdelkasafe.ru/tonconnect-manifest.json"

# SMTP для писем (подтверждение email, дайджест) — опционально
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SdelkaSafe <no-reply@sdelkasafe.ru>"
