# Скопируй в .env и заполни значения

# PostgreSQL
DATABASE_URL="postgresql://sdelka:sdelka_pass@localhost:5433/sdelka_db?schema=public"

# NextAuth
NEXTAUTH_SECRET="смени-на-случайную-строку"
NEXTAUTH_URL="http://localhost:3000"

# Telegram (бот и Mini App)
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="SdelkaSafeBot"
TELEGRAM_WEBHOOK_SECRET="change-me-webhook-secret"
APP_URL="http://localhost:3000"
ADMIN_TELEGRAM_CHAT_ID=""

# SMTP для подтверждения email (если не задано — код виден в dev-режиме)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SdelkaSafe <no-reply@sdelkasafe.ru>"

# TON
PLATFORM_TON_WALLET="EQ...адрес-кошелька-платформы"
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL="https://sdelkasafe.ru/tonconnect-manifest.json"
